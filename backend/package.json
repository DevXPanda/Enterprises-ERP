{
  "name": "nktech-erp-api",
  "version": "1.0.0",
  "description": "NKTech ERP backend — NestJS + TypeORM + PostgreSQL (Neon)",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "seed": "ts-node -P tsconfig.json src/seed/run-seed.ts",
    "purge": "ts-node -P tsconfig.json src/seed/purge.ts",
    "wages:schema": "ts-node -P tsconfig.json src/wages/apply-schema.ts",
    "wages:seed": "ts-node -P tsconfig.json src/seed/seed-wages.ts",
    "lint": "eslint \"src/**/*.ts\""
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/typeorm": "^11.0.0",
    "dotenv": "^16.4.5",
    "pg": "^8.16.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.25",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
